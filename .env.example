# 特特管家推送配置
API_TOKEN=your_tete_guanjia_token_here

# Teslamate 数据库（docker-compose 中 service 名必须是 database）
DATABASE_HOST=database
DATABASE_USER=teslamate
DATABASE_PASS=your_secure_password
DATABASE_NAME=teslamate
DATABASE_PORT=5432

# MQTT（docker-compose 中 service 名必须是 mosquitto）
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=   # 留空或填你的用户名
MQTT_PASS=   # 留空或填你的密码

# 其他配置
CAR_ID=1                    # 你的车辆ID，默认1
LOG_LEVEL=info              # debug / info / warn
PUSH_DEBOUNCE_SECONDS=5    # 推送防抖动初始时间